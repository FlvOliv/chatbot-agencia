# =============================================================================
# Malu Bot — Lu Milhas & Viagens
# Copie este arquivo para `.env` e preencha com seus secrets reais.
# NUNCA commite o `.env`.
# =============================================================================

# --- Meta WhatsApp Cloud API ---
# Token permanente da Meta Cloud API (Developer Console → System User Token)
WA_TOKEN=your_permanent_access_token
# ID do número de telefone (Developer Console → WhatsApp → API Setup)
WA_PHONE_ID=your_phone_number_id
# String aleatória — usada no handshake de verificação do webhook
WA_VERIFY_TOKEN=qualquer_string_aleatoria
# App secret do app Meta — usado para validar HMAC-SHA256 das requisições
WA_APP_SECRET=seu_app_secret_meta

# --- Google Gemini (provider primário) ---
# Chave gratuita: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GEMINI_MODEL=gemini-2.5-flash

# --- Groq (stand-by — pra ativar: AI_PRIMARY=groq) ---
# Chave gratuita: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# --- Banco e cache ---
DATABASE_URL=postgresql+asyncpg://malu:malu@localhost:5433/malu
REDIS_URL=redis://localhost:6379/0

# --- Negócio ---
# Telefone da Luciana (atendente humana) no formato E.164 sem '+'
LUCIANA_PHONE=5511999999999
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=18

# --- IA ---
# "gemini" | "groq" | "claude" | "openai" | "gemma"
AI_PRIMARY=gemini
# "gemma" | "none"
AI_FALLBACK=none
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
SESSION_TTL_SECONDS=86400

# --- CRM API (consumida pelo frontend Next.js) ---
# String secreta — usada como header X-API-Key nas rotas /api/*
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
CRM_API_KEY=
# Origens permitidas no CORS (separadas por vírgula)
CRM_CORS_ORIGINS=http://localhost:3000

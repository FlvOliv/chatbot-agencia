# URL base da API FastAPI (sem /api)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Chave usada em X-API-Key — SERVER ONLY, nunca expor no client.
# Deve bater com a mesma chave configurada no backend.
CRM_API_KEY=cole-aqui-a-mesma-key-do-backend

# Configs visuais (lidas em /configuracoes — sem secrets)
NEXT_PUBLIC_LUCIANA_PHONE=5511999999999
NEXT_PUBLIC_AI_PRIMARY=claude
NEXT_PUBLIC_AI_FALLBACK=gemma
NEXT_PUBLIC_BUSINESS_HOURS_START=9
NEXT_PUBLIC_BUSINESS_HOURS_END=18
